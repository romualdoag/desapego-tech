    }

    .language-options {
        display: flex;
        flex-direction: column;
        gap: 15px;
        margin-top: 20px;
    }

    .language-btn {
        padding: 10px 20px;
        background: #f0f0f0;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        text-decoration: none;
        color: #333;
    }

    .language-btn:hover {
        background: #e0e0e0;
    }

    .close-btn {
        position: absolute;
        right: 10px;
        top: 10px;
        background: none;
        border: none;
        font-size: 20px;
        cursor: pointer;
        padding: 5px 10px;
    }
    </style>

    <script>
    jQuery(document).ready(function($) {
        // 檢查 sessionStorage 中是否已經顯示過
        if (!sessionStorage.getItem('language_popup_shown')) {
            $('#language-popup').show();
            // 設置 sessionStorage 標記
            sessionStorage.setItem('language_popup_shown', 'true');
        }

        // 點擊語言按鈕時關閉彈窗
        $('.language-btn').click(function() {
            $('#language-popup').hide();
        });

        // 添加關閉按鈕的功能
        $('.popup-content').append('<button class="close-btn">&times;</button>');
        $('.close-btn').click(function() {
            $('#language-popup').hide();
        });

        // 點擊背景時關閉彈窗
        $('.language-popup').click(function(e) {
            if (e.target === this) {
                $('#language-popup').hide();
            }
        });
    });
    </script>
    <div class="wpc-filters-overlay"></div>
